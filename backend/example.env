# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
TRUST_PROXY=1

# Database
MONGODB_URI=mongodb://localhost:27017/ai-syllabus-analyzer

# Auth
JWT_SECRET=change_me_strong_password
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-key
LLM_MODEL=gpt-5.4-mini
LLM_REASONING_EFFORT=medium
LLM_MAX_OUTPUT_TOKENS=12000

# Timeouts
REQUEST_TIMEOUT_MS=20000
AI_REQUEST_TIMEOUT_MS=130000
KEEP_ALIVE_TIMEOUT_MS=65000

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=120
CHAT_MESSAGE_RATE_LIMIT=30

# Admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator

# Uploads
MAX_FILE_SIZE=10485760

# Email
EMAIL_FROM=KSE AI Analyzer <no-reply@example.com>
GMAIL_USER=
GMAIL_PASS=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# PDF rendering
PUPPETEER_EXECUTABLE_PATH=

# Google Forms webhook
BACKEND_URL=http://localhost:5000
GF_WEBHOOK_SECRET=
